{
  "enabledPlugins": {
    "terraform-skill@antonbabenko": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *_test.go) ;; *.go) make generate ;; esac; } 2>/dev/null || true",
            "timeout": 60,
            "statusMessage": "Regenerating docs..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "OTEL_TRACES_EXPORTER= pre-commit run -a 2>&1",
            "timeout": 120,
            "statusMessage": "Running pre-commit hooks..."
          }
        ]
      }
    ]
  }
}
